# ─── TRANSLATION API (Google AI Studio) ──────────────────────────────────
# Your Google AI Studio or Gemini API Key
GOOGLE_AI_STUDIO_API_KEY=your_google_api_key_here
# The primary model to use for translations (e.g. gemini-2.5-flash)
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-flash
# Comma-separated list of fallback models if the primary one hits rate limits
GOOGLE_AI_STUDIO_FALLBACK_MODELS=gemini-2.0-flash-lite,gemini-2.0-flash

# ─── ADMIN DASHBOARD ───────────────────────────────────────────────────────
# Password required to log into the /admin dashboard
ADMIN_PASSWORD=your_secure_password_here

# ─── FIREBASE CONFIGURATION ────────────────────────────────────────────────
# Firebase project configuration (can be found in Firebase Console -> Project Settings)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id
